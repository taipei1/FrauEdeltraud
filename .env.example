
# Telegram bot token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Groq API key (get from https://console.groq.com/)
GROQ_API_KEY=your_groq_api_key_here

# AssemblyAI API key (for executer2, optional)
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# Language settings
LANGUAGE_LEVEL=A2
TARGET_LANGUAGE=en
PROMPT_LANGUAGE=en
STT_LANGUAGE=ru

# Voice settings (see edge-tts --list-voices)
EDGE_TTS_VOICE=en-US-JennyNeural
EDGE_TTS_RATE=+0%
EDGE_TTS_PITCH=+0Hz

# Optional: allowed chat IDs (comma-separated, empty = allow all)
ALLOWED_CHAT_IDS=

# LangSmith tracing (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=frauEdeltraud

# Vector translator settings (optimal from 108-config grid search, score=0.752)
TRANSLATOR_TEMPERATURE=0.5
TRANSLATOR_TOP_K=8
TRANSLATOR_MAX_VOCAB=250
TRANSLATOR_THRESHOLD=0.55
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDINGS_CACHE_DIR=cache
EMBEDDING_BACKEND=local
