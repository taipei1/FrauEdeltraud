# Telegram bot token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# LLM API keys (at least one required)
GROQ_API_KEY=your_groq_api_key_here
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Optional: AssemblyAI for speaker diarization
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# Language settings
DUB_SOURCE_LANGUAGE=en
DUB_TARGET_LANGUAGE=ru

# Groq Whisper model
DUB_WHISPER_MODEL=whisper-large-v3

# LLM model (defaults to GroQ's llama-3.1-8b-instant)
DUB_LLM_MODEL=llama-3.1-8b-instant

# LLM provider: groq or deepseek
LLM_PROVIDER=groq

# Voice settings
EDGE_TTS_RATE=+0%
EDGE_TTS_PITCH=+0Hz

# Performance
DUB_MAX_PARALLEL=4
DUB_MAX_DURATION=30

# Directories
DUB_TEMP_DIR=tmp/video_dub
DUB_OUTPUT_DIR=results/dubs
DUB_TTS_CACHE_DIR=cache/tts_dub

# Optional: allowed chat IDs (comma-separated, empty = allow all)
ALLOWED_CHAT_IDS=
